# Copy this file to config/recent-chat.env and fill in real values.
RECENT_CHAT_MYSQL_DSN=YOUR_MYSQL_DSN
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=bge-m3
QDRANT_BASE_URL=http://127.0.0.1:6333
# recent-chat reads these collections; explicit teaching demos create and index them.
QDRANT_MEMORY_COLLECTION=offline_rag_memory_items_v1
QDRANT_DOCUMENT_COLLECTION=offline_rag_document_chunks_v1
RECENT_CHAT_TOKENIZER_PATH=assets/tokenizers/qwen2/tokenizer.json
SESSION_SUMMARY_MIN_MESSAGES=8
SESSION_SUMMARY_MIN_TOKENS=2048
SESSION_SUMMARY_INPUT_RESERVE=1024
SESSION_SUMMARY_OUTPUT_LIMIT=512
MEMORY_STORE_SCHEMA_PATH=sql/memory_items.sql
DOCUMENT_INGEST_SCHEMA_PATH=sql/document_ingestion.sql
DOCUMENT_INGEST_COLLECTION_V1=offline_rag_document_ingestion_lab_v1
DOCUMENT_INGEST_COLLECTION_V2=offline_rag_document_ingestion_lab_v2
DOCUMENT_INGEST_ALIAS=offline_rag_document_ingestion_lab_active
